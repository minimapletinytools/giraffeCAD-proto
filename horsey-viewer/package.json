{
  "name": "horsey-viewer",
  "displayName": "Horsey Viewer",
  "description": "Timber frame viewer for GiraffeCAD",
  "version": "0.0.1",
  "publisher": "giraffeCAD",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:horsey-viewer.renderHorsey",
    "onLanguage:python"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "horsey-viewer.renderHorsey",
        "title": "Render Horsey"
      },
      {
        "command": "horsey-viewer.browsePatterns",
        "title": "Browse Patterns"
      },
      {
        "command": "horsey-viewer.unloadPattern",
        "title": "Unload Pattern Viewer"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "echo 'No build step needed'",
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:runner": "jest --runInBand __tests__/runner-protocol.test.js",
    "test:ext": "node ./test/run-extension-tests.js",
    "test:all": "npm run test:unit && npm run test:ext"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@types/vscode": "^1.60.0",
    "jest": "^29.7.0"
    ,"mocha": "^11.2.2"
  }
}
